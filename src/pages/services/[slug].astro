---
import { getEntry, getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import QuoteForm from '../../components/QuoteForm.tsx';
import PromoCard from '../../components/PromoCard.astro';
import BeforeAfterSlider from '../../components/BeforeAfterSlider.tsx';
import PricingTierCards from '../../components/PricingTierCards.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const service = await getEntry('services', slug);
if (!service) return Astro.redirect('/404');

const { Content } = await service.render();
const { weatherContext } = Astro.locals as { weatherContext?: any } || {};
const urgency = weatherContext?.urgency || 1;
const city = weatherContext?.city || 'Melbourne';

// Get other services for related links
const allServices = await getCollection('services');
const relatedServices = allServices.filter(s => s.slug !== slug);

// Inline SVG icon map \u2014 covers all 6 service icon field values
const svgIcons: Record<string, string> = {
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  'shield-check': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  'shield-exclamation': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  'building-office-2': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="1"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
};
const defaultIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;

const pageTitle = `${service.data.title} | True Roof Melbourne`;
const pageDescription = service.data.description;

// Construct dynamic Service schema connecting the WebPage -> Service -> LocalBusiness
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `https://trueroof.com.au/services/${slug}#service`,
  "name": service.data.title,
  "description": service.data.description,
  "provider": {
    "@type": "RoofingContractor",
    "@id": "https://trueroof.com.au/#business",
    "name": "True Roof"
  },
  "areaServed": {
    "@type": "City",
    "name": city
  }
};
---
<MainLayout title={pageTitle} description={pageDescription} schema={serviceSchema}>

  {/* ── Service Hero ── */}
  <section class="hero-section" style="padding: 4rem 0 3.5rem;">
    <div class="hero-content">
      <div class="hero-badge" style="display: inline-flex; align-items: center; gap: 0.5rem;">
        <span set:html={svgIcons[service.data.icon || ''] || defaultIcon} />
        {service.data.title}
      </div>
      <h1 class="hero-headline" style="font-size: clamp(2rem, 5vw, 3.5rem);">
        {service.data.title}
      </h1>
      <p class="hero-sub" style="max-width: 42rem;">
        {service.data.description}
      </p>
      <div class="hero-ctas">
        <a href="#quote" class="cta-primary">
          {urgency >= 4 ? '🚨 Emergency Booking' : '📋 Get a Free Quote'}
        </a>
        <a href="tel:0400000000" class="cta-secondary">📞 Call Us Now</a>
      </div>
    </div>
  </section>

  {/* ── Service Content ── */}
  {/* 📐 Pixel: Enforcing F-Pattern reading mode alongside a sticky Z-Pattern CTA aside */}
  <section style="padding: 4rem 0;">
    <div class="container grid grid-cols-1 md:grid-cols-[1fr_20rem] gap-8 md:gap-16 items-start">

      {/* Main Content */}
      <div class="content-prose">
        <Content components={{ BeforeAfterSlider, PricingTierCards }} />
      </div>

      {/* Sidebar CTA */}
      <aside class="md:sticky md:top-24">
        <div class="glass-card" style={`padding: 2rem; text-align: center; ${urgency >= 4 ? 'background: rgba(239, 68, 68, 0.05); border-color: rgba(239, 68, 68, 0.2); animation: pulseGlow 2s infinite;' : ''}`}>
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">{urgency >= 4 ? '🚨' : '📋'}</div>
          <h3 style="font-family: Outfit, sans-serif; font-weight: 800; font-size: 1.15rem; color: white; margin-bottom: 0.5rem;">
            {urgency >= 4 ? 'Urgent Damage Assessment' : 'Free Roof Inspection'}
          </h3>
          <p style="color: rgba(255,255,255,0.45); font-size: 0.85rem; line-height: 1.5; margin-bottom: 1.25rem;">
            {urgency >= 4 ? 'Priority response for active leaks and storm damage.' : 'No obligation quote with a detailed condition report.'}
          </p>
          <a href="#quote" class="cta-primary" style="width: 100%; font-size: 0.9rem;">
            {urgency >= 4 ? 'Request Urgent Help' : 'Get Your Quote'}
          </a>
          <div style="margin-top: 1rem; display: flex; justify-content: center; gap: 0.5rem;">
            <span class="badge" style={`font-size: 0.7rem; ${urgency >= 4 ? 'background: rgba(239,68,68,0.15); color: #fca5a5; border-color: rgba(239,68,68,0.3);' : ''}`}>{urgency >= 4 ? '🚨 Priority' : '✅ Free'}</span>
            <span class="badge" style={`font-size: 0.7rem; ${urgency >= 4 ? 'background: rgba(239,68,68,0.15); color: #fca5a5; border-color: rgba(239,68,68,0.3);' : ''}`}>{urgency >= 4 ? '🛡️ Fully Insured' : '✅ Same Day'}</span>
          </div>
        </div>

        {/* Phone Card */}
        <div class="glass-card" style={`padding: 1.5rem; margin-top: 1rem; display: flex; align-items: center; gap: 0.75rem; ${urgency >= 4 ? 'background: rgba(239, 68, 68, 0.05); border-color: rgba(239, 68, 68, 0.2);' : ''}`}>
          <span style="font-size: 1.5rem;">📞</span>
          <div>
            <div style={`font-size: 0.7rem; color: ${urgency >= 4 ? '#fca5a5' : 'rgba(255,255,255,0.4)'}; text-transform: uppercase; letter-spacing: 0.04em;`}>{urgency >= 4 ? 'Emergency Line' : 'Call Anytime'}</div>
            <a href="tel:0400000000" style="font-family: Outfit, sans-serif; font-weight: 800; font-size: 1.1rem; color: white; text-decoration: none;">0400 000 000</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {/* ── Related Services ── */}
  {relatedServices.length > 0 && (
    <section class="section-dark" style="padding: 4rem 0;">
      <div class="container">
        <h2 class="section-heading" style="margin-bottom: 2rem;">Other <span class="accent-text">Services</span></h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">
          {relatedServices.map(s => (
            <a href={`/services/${s.slug}`} class="service-card">
              <div class="service-icon" set:html={svgIcons[s.data.icon || ''] || defaultIcon} />
              <h3>{s.data.title}</h3>
              <p>{s.data.description}</p>
              <span class="card-link">Learn More →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Quote Section ── */}
  {/* 📐 Pixel: Enforcing Z-Pattern flow towards the lead capture form on desktop */}
  <section id="quote" class="quote-section">
    <div class="container grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div>
        <h2 class="section-heading" style="margin-bottom: 1rem;">
          {urgency >= 4 ? 'Urgent Response for' : 'Get a Quote for'}<br/><span class="accent-text">{service.data.title}</span>
        </h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem;">
          {urgency >= 4
            ? "Weather is active — the sooner we assess your roof, the less damage occurs. Fill in your details and we'll call back within the hour."
            : "Tell us about your roof and we'll get back to you with a detailed quote within 2 hours."}
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <span class="badge">✅ Free Inspections</span>
          <span class="badge">✅ No Obligation</span>
          {urgency >= 4 && <span class="badge" style="background: rgba(239,68,68,0.15); color: #fca5a5; border-color: rgba(239,68,68,0.3);">🚨 Urgent Response</span>}
        </div>
        <PromoCard contextType="service" serviceName={service.data.title} />
      </div>
      <QuoteForm client:load ctx={weatherContext} />
    </div>
  </section>

</MainLayout>
