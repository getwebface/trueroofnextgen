---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import TrustBar from '../components/TrustBar.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import WeatherHero from '../components/WeatherHero.tsx';
import QuoteForm from '../components/QuoteForm.tsx';
import SmartFAQAccordion from '../components/SmartFAQAccordion.tsx';
import PromoCard from '../components/PromoCard.astro';
import TextureTechnology from '../components/TextureTechnology.astro';
import SmartMedia from '../components/SmartMedia.astro';
import { rankFAQs } from '../utils/faqRanker';

const locations = await getCollection('locations');
const services = await getCollection('services');
const faqs = await getCollection('faqs');

const { weatherContext } = Astro.locals;

// SVG icon map — inline SVG paths keyed by content icon field value
// Using a subset of Lucide icons, stroke="currentColor" strokeWidth="1.5"
const svgIcons: Record<string, string> = {
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  'shield-check': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  'shield-exclamation': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  'building-office-2': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="1"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
};
const defaultIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;

// Build service → urgency hint
const serviceUrgencyMap: Record<string, string> = {};
if (weatherContext) {
  for (const sig of weatherContext.services) {
    serviceUrgencyMap[sig.slug] = sig.trigger;
  }
}

// ── Smart FAQ ranking ─────────────────────────────────────────────────────────
// Map content collection entries into RankableFAQ shape and run the ranker.
// The ranker handles all ordering — no manual sort, no hardcoded lists.
const rankableFaqs = faqs.map(f => ({
  slug: f.slug,
  question: f.data.question,
  answer: f.data.answer,
  category: f.data.category ?? 'general',
  services: f.data.services ?? [],
  weatherEvents: f.data.weatherEvents ?? [],
  tags: f.data.tags ?? [],
  basePriority: f.data.basePriority ?? 5,
}));

const rankedFaqs = rankFAQs(rankableFaqs, weatherContext);


// Weather-informed service ordering
const serviceOrder = weatherContext?.services.map(s => s.slug) || [];
// Pre-calculate Map of indices for O(1) lookups instead of repeated indexOf calls inside sort
const serviceOrderMap = new Map();
serviceOrder.forEach((slug, i) => serviceOrderMap.set(slug, i));

const sortedServices = [...services].sort((a, b) => {
  const ai = serviceOrderMap.get(a.slug) ?? -1;
  const bi = serviceOrderMap.get(b.slug) ?? -1;
  if (ai === -1 && bi === -1) return 0; // neither in order list
  if (ai === -1) return 1; // a not in list, put b first
  if (bi === -1) return -1; // b not in list, put a first
  return ai - bi; // both in list, sort by order
});
---
<MainLayout title="True Roof — Melbourne Tile Restoration Specialists" description="Melbourne's trusted tile restoration experts. Professional cleaning, re-bedding, flexi-pointing, metal flashing repairs. Free inspections. 25+ years experience.">

  <!-- Hero Section — SmartMedia full-bleed background + React weather overlay -->
  <div class="hero-smart-wrapper">
    {/* SmartMedia background: prefer video, fallback to weather/location image */}
    <div class="hero-smart-bg" aria-hidden="true">
      <SmartMedia
        contextKeywords={[
          'hero',
          'roof',
          weatherContext?.event?.toLowerCase().replace('_', '-') ?? 'clear',
          weatherContext?.city?.toLowerCase() ?? 'melbourne',
        ]}
        alt=""
        cssClass="hero-smart-media"
        preferredType="any"
      />
    </div>
    <WeatherHero client:load ctx={weatherContext} />
  </div>

  <!-- Trust Bar -->
  <TrustBar ctx={weatherContext} />

  <!-- Services Section — weather-ranked order -->
  <section id="services" class="py-20">
    <div class="container">
      <div style="margin-bottom: 3rem;">
        <h2 class="section-heading">Our Restoration <span class="accent-text">Services</span></h2>
        <p class="section-subheading">
          {weatherContext?.copyHints?.seasonalTip || 'Specialized care for Melbourne\'s terracotta and concrete tile roofs — from cleaning to full restoration.'}
        </p>
      </div>

      {weatherContext?.urgency && weatherContext.urgency <= 2 && (
        <div style="margin-bottom: 3rem; background: rgba(245, 158, 11, 0.05); border: 1px solid rgba(245, 158, 11, 0.2); border-radius: var(--radius-card); padding: 1.5rem; display: flex; align-items: flex-start; gap: 1rem;">
          <div style="font-size: 1.5rem; margin-top: 0.1rem;">💡</div>
          <div>
            <h4 style="font-family: Outfit, sans-serif; font-weight: 700; font-size: 1.1rem; color: #fbbf24; margin-bottom: 0.25rem;">Ideal Conditions for Preventative Maintenance</h4>
            <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.5; margin: 0;">
              {weatherContext?.copyHints?.seasonalTip || 'Current weather is perfect for roof inspections and restorative work. Book now before conditions change.'}
            </p>
          </div>
        </div>
      )}

      <!-- Tier 1: Top 3 weather-ranked services as full feature cards -->
      <div class="services-featured-grid">
        {sortedServices.slice(0, 3).map((service, i) => {
          const hint = serviceUrgencyMap[service.slug];
          const icon = svgIcons[service.data.icon || ''] || defaultIcon;
          return (
            <a href={`/services/${service.slug}`} class={`service-card ${i === 0 ? 'featured' : ''}`} aria-label={`Learn more about our ${service.data.title} service`}>
              {/* Contextual SmartMedia Thumbnail */}
              <div class="service-card-media" aria-hidden="true">
                <SmartMedia
                  contextKeywords={['service', ...service.slug.split('-')]}
                  alt=""
                  cssClass="service-media-img"
                  preferredType="image"
                />
                <div class="service-card-media-overlay"></div>
              </div>
              <div class="service-card-content">
                <div class="service-icon" set:html={icon} />
                <h3>{service.data.title}</h3>
                <p>{service.data.description}</p>
                {hint && <div class="service-hint">📍 {hint}</div>}
                <span class="card-link">Learn about {service.data.title} →</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Tier 2: Remaining services as compact horizontal tiles -->
      {sortedServices.length > 3 && (
        <div class="services-compact-row">
          <div class="services-compact-label">Also Available</div>
          <div class="services-compact-list">
            {sortedServices.slice(3).map((service) => {
              const icon = svgIcons[service.data.icon || ''] || defaultIcon;
              return (
                <a href={`/services/${service.slug}`} class="service-compact-tile" aria-label={`Learn more about our ${service.data.title} service`}>
                  <span class="service-compact-icon" set:html={icon} />
                  <div class="service-compact-body">
                    <div class="service-compact-title">{service.data.title}</div>
                    <div class="service-compact-desc">{service.data.description.slice(0, 72)}…</div>
                  </div>
                  <span class="service-compact-arrow">→</span>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- 4-Stage Process -->
  <div id="process" class="section-dark">
    <ProcessSteps />
  </div>

  <!-- Texture Technology: hydrophobic coating video showcase -->
  <TextureTechnology />

  <!-- Locations Section -->
  <section id="locations" class="py-20">
    <div class="container">
      <div style="margin-bottom: 3rem;">
        <h2 class="section-heading">Serving <span class="accent-text">Melbourne</span> & Beyond</h2>
        <p class="section-subheading">Find your suburb and see what's relevant for your area right now.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">
        {locations.map(location => (
          <a href={`/locations/${location.slug}`} class="location-card" aria-label={`Roof restoration services in ${location.data.title}`}>
            {/* Contextual SmartMedia Location Thumbnail */}
            <div class="location-card-media" aria-hidden="true">
              <SmartMedia
                contextKeywords={['location', location.slug, ...location.data.title.toLowerCase().split(/\s+/)]}
                alt=""
                cssClass="location-media-img"
                preferredType="image"
              />
              <div class="location-card-media-overlay"></div>
            </div>
            <div class="location-card-content">
              <h3>{location.data.title}</h3>
              <p>{location.data.description}</p>
              {location.data.localStats?.avgRoofAge && (
                <div style="margin-top: 0.75rem;">
                  <span class="badge">Avg Roof Age: {location.data.localStats.avgRoofAge}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-dark py-20">
    <div class="container" style="max-width: 52rem;">
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <h2 class="section-heading">Common <span class="accent-text">Questions</span></h2>
        <p class="section-subheading" style="margin-left: auto; margin-right: auto;">
          {weatherContext?.copyHints?.weatherDescription
            ? `Questions most relevant during ${weatherContext.copyHints.weatherDescription} — sorted by what matters right now.`
            : 'Everything you need to know about tile roof restoration in Melbourne.'}
        </p>
      </div>
      <SmartFAQAccordion
        client:visible
        items={rankedFaqs}
        weatherEvent={weatherContext?.event}
      />
    </div>
  </section>

  <!-- Quote Section -->
  <!-- 📐 Pixel: Enforcing Z-Pattern flow towards the lead capture form on desktop -->
  <section id="quote" class="quote-section">
    <div class="container grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div>
        <h2 class="section-heading" style="margin-bottom: 1rem;">
          Ready to Restore<br/><span class="accent-text">Your Roof?</span>
        </h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem;">
          {weatherContext?.urgency && weatherContext.urgency >= 4
            ? 'Weather is active — the sooner we assess your roof, the less damage occurs. Fill in your details and we\'ll call back within the hour.'
            : 'Fill in the form and one of our team will call you back within 2 hours. Or call us directly — we\'re always happy to chat.'}
        </p>
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
          <span style="font-size: 2rem;">📞</span>
          <div>
            <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.05em;">
              {weatherContext?.urgency && weatherContext.urgency >= 4 ? 'Emergency Line — Call Now' : 'Call Us Anytime'}
            </div>
            <a href="tel:0400000000" style="font-family: Outfit, sans-serif; font-weight: 800; font-size: 1.5rem; color: white; text-decoration: none;">0400 000 000</a>
          </div>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <span class="badge">✅ Free Inspections</span>
          <span class="badge">✅ No Obligation</span>
          {weatherContext?.urgency && weatherContext.urgency >= 4 && <span class="badge" style="background: rgba(239,68,68,0.15); color: #fca5a5; border-color: rgba(239,68,68,0.3);">🚨 Urgent Response</span>}
        </div>
        <PromoCard contextType="home" />

        <!-- 🧠 Convert UX: Placing social proof immediately adjacent to the lead capture form significantly increases conversion rates by providing third-party validation at the highest point of friction. -->
        <div class="glass-card" style="margin-top: 2rem; padding: 1.5rem; background: rgba(255,255,255,0.02); border-left: 4px solid var(--color-brand-orange);">
          <div style="display: flex; gap: 0.25rem; color: #f59e0b; margin-bottom: 0.75rem; font-size: 1.1rem;">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p style="color: rgba(255,255,255,0.8); font-size: 0.95rem; line-height: 1.6; font-style: italic; margin-bottom: 1rem;">
            "These guys are the real deal. Had a leak for months that two other companies couldn't fix. True Roof found it in 10 minutes and sorted the whole roof. Highly recommend."
          </p>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 2.5rem; height: 2.5rem; background: rgba(249, 115, 22, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Outfit', sans-serif; font-weight: 700; color: white;">
              MB
            </div>
            <div>
              <div style="font-family: 'Outfit', sans-serif; font-weight: 700; color: white; font-size: 0.95rem;">Mark B.</div>
              <div style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Melbourne, Verified Customer</div>
            </div>
          </div>
        </div>
      </div>
      <QuoteForm client:visible ctx={weatherContext} />
    </div>
  </section>

</MainLayout>

<style>
  /* ── Hero SmartMedia background wrapper ── */
  .hero-smart-wrapper {
    position: relative;
    overflow: hidden;
  }

  .hero-smart-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-smart-bg .hero-smart-media,
  .hero-smart-bg .smart-video-wrapper,
  .hero-smart-bg .smart-media-picture,
  .hero-smart-bg .smart-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  /* Ensure the React WeatherHero sits on top */
  .hero-smart-wrapper > :not(.hero-smart-bg) {
    position: relative;
    z-index: 1;
  }


  /* ── Services: SVG icon in card ── */
  .service-icon svg {
    display: block;
  }

  /* ── Tier 1: Featured grid (top 3 cards) ── */
  .services-featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .service-card {
    padding: 0;
  }

  /* Thumbnail for service cards */
  .service-card-media {
    position: relative;
    width: 100%;
    height: 140px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(249,115,22,0.05), rgba(15,15,35,0.8));
  }

  .service-card-media .service-media-img,
  .service-card-media .smart-media-picture,
  .service-card-media .smart-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .service-card:hover .service-card-media .service-media-img,
  .service-card:hover .service-card-media .smart-media-picture,
  .service-card:hover .service-card-media .smart-media-img {
    transform: scale(1.05);
  }

  .service-card-media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(26,26,46,1) 100%);
    pointer-events: none;
  }

  .service-card-content {
    padding: 1.5rem 2rem 2rem;
    position: relative;
    z-index: 1;
    margin-top: -1.5rem;
  }

  .service-card.featured {
    border-top: none;
    box-shadow: 0 0 0 2px var(--color-brand-orange);
  }

  .service-hint {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    font-style: italic;
    margin-bottom: 0.75rem;
    padding: 0.375rem 0.75rem;
    background: rgba(255,255,255,0.03);
    border-radius: 0.5rem;
    border-left: 2px solid rgba(249, 115, 22, 0.4);
  }

  /* ── Tier 1: Featured grid (top 3 cards) ── */
  .services-featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* ── Tier 2: Compact "Also Available" row ── */
  .services-compact-row {
    margin-top: 0.5rem;
  }

  .services-compact-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 0.75rem;
  }

  .services-compact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-compact-tile {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border-radius: var(--radius-card);
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-compact-tile:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(249, 115, 22, 0.25);
    transform: translateX(4px);
  }

  .service-compact-icon {
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(249, 115, 22, 0.08);
    border-radius: 0.625rem;
  }

  .service-compact-icon svg {
    display: block;
  }

  .service-compact-body {
    flex: 1;
    min-width: 0;
  }

  .service-compact-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    margin-bottom: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .service-compact-desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .service-compact-arrow {
    color: var(--color-brand-orange);
    font-weight: 700;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .service-compact-tile:hover .service-compact-arrow {
    transform: translateX(4px);
  }

  /* ── Location Cards ── */
  .location-card {
    padding: 0;
  }

  .location-card-media {
    position: relative;
    width: 100%;
    height: 120px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(59,130,246,0.05), rgba(15,15,35,0.8));
  }
  
  .location-card-media .location-media-img,
  .location-card-media .smart-media-picture,
  .location-card-media .smart-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .location-card:hover .location-card-media .location-media-img,
  .location-card:hover .location-card-media .smart-media-picture,
  .location-card:hover .location-card-media .smart-media-img {
    transform: scale(1.05);
  }

  .location-card-media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 30%, rgba(26,26,46,1) 100%);
    pointer-events: none;
  }

  .location-card-content {
    padding: 1.25rem 1.75rem 1.75rem;
    position: relative;
    z-index: 1;
    margin-top: -1.25rem;
  }

  @media (max-width: 640px) {
    .service-compact-desc { display: none; }
    .service-compact-tile { padding: 0.75rem 1rem; }
  }
</style>
