---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');
const services = await getCollection('services');
---
<MainLayout>
  <section class="py-12 text-center">
    <h1 class="text-6xl font-black tracking-tighter mb-6">MELBOURNE'S TILE RESTORATION SPECIALISTS</h1>
    <p class="text-xl text-slate-600 max-w-2xl mx-auto mb-10">
      We don't just replace roofs; we restore them to their former glory. Specialized care for Melbourne's terracotta and concrete tile roofs.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/services/cleaning" class="bg-blue-600 text-white px-8 py-3 rounded-full font-bold hover:bg-blue-700 transition-colors">Our Services</a>
      <a href="#locations" class="border border-slate-200 px-8 py-3 rounded-full font-bold hover:bg-slate-50 transition-colors">View Locations</a>
    </div>
  </section>

  <section id="locations" class="py-12 border-t border-slate-100">
    <h2 class="text-3xl font-bold mb-8">Serving Melbourne & Beyond</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {locations.map(location => (
        <a href={`/locations/${location.slug}`} class="group p-6 bg-white rounded-2xl shadow-sm hover:shadow-md transition-all border border-slate-100">
          <h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors">{location.data.title}</h3>
          <p class="text-slate-500 text-sm mt-2">{location.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="py-12 border-t border-slate-100">
    <h2 class="text-3xl font-bold mb-8">Our Restoration Services</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <div class="p-8 bg-slate-900 text-white rounded-3xl">
          <h3 class="text-2xl font-bold mb-4">{service.data.title}</h3>
          <p class="text-slate-400 mb-6">{service.data.description}</p>
          <a href={`/services/${service.slug}`} class="text-blue-400 font-bold hover:underline">Learn More &rarr;</a>
        </div>
      ))}
    </div>
  </section>
</MainLayout>
