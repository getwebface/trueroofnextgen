---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(location => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const { Content } = await location.render();
const { weatherContext } = Astro.locals;

// Check for weather overrides
const overrideHeadline = location.data.weatherOverrides?.[weatherContext?.weatherMode as keyof typeof location.data.weatherOverrides];
const headline = overrideHeadline || location.data.title;
---
<MainLayout>
  <h1 class="text-5xl font-bold mb-4">{headline}</h1>
  <p class="text-xl text-slate-600 mb-8">{location.data.description}</p>
  
  {location.data.localStats && (
    <div class="bg-white p-6 rounded-xl shadow-sm mb-8 grid grid-cols-2 gap-4">
      {location.data.localStats.avgRoofAge && (
        <div><span class="block text-sm text-slate-500">Avg Roof Age</span><span class="font-bold">{location.data.localStats.avgRoofAge}</span></div>
      )}
      {location.data.localStats.lastStormDate && (
        <div><span class="block text-sm text-slate-500">Last Storm</span><span class="font-bold">{location.data.localStats.lastStormDate}</span></div>
      )}
    </div>
  )}

  <div class="prose prose-slate max-w-none">
    <Content />
  </div>
</MainLayout>
