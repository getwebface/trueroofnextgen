---
import { getEntry, getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import QuoteForm from '../../components/QuoteForm.tsx';
import FAQAccordion from '../../components/FAQAccordion.tsx';
import PromoCard from '../../components/PromoCard.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const location = await getEntry('locations', slug);
if (!location) return Astro.redirect('/404');

const { Content } = await location.render();
const { weatherContext } = Astro.locals;
const event = weatherContext?.event;
const urgency = weatherContext?.urgency || 1;

// Weather-reactive headline — maps event to location-specific override
const eventToMode: Record<string, string> = {
  HAIL_STORM: 'STORM_EMERGENCY',
  THUNDERSTORM: 'STORM_EMERGENCY',
  HIGH_WIND: 'STORM_EMERGENCY',
  HEAVY_RAIN: 'RAIN_ACTIVE',
  DRIZZLE: 'RAIN_ACTIVE',
  FROST: 'PREVENTATIVE',
  OVERCAST: 'PREVENTATIVE',
  FOG: 'PREVENTATIVE',
  CLEAR_MILD: 'ROOF_RESTORATION',
  CLEAR_HOT: 'ROOF_RESTORATION',
};
const overrideKey = event ? (eventToMode[event] || 'DEFAULT') : 'DEFAULT';
const overrideHeadline = location.data.weatherOverrides?.[overrideKey as keyof typeof location.data.weatherOverrides];
const headline = overrideHeadline || location.data.title;

// Get FAQs for this location
const allFaqs = await getCollection('faqs');
const locationFaqs = allFaqs
  .filter(f => f.data.locationSlug === slug || !f.data.locationSlug)
  .map(f => ({ question: f.data.question, answer: f.data.answer }));

// Get services for cross-linking
const services = await getCollection('services');

const pageTitle = `Roof Restoration in ${location.data.title} | True Roof`;
const pageDescription = location.data.description;

// Construct dynamic LocalBusiness schema connecting the WebPage -> LocalBusiness -> City
const locationSchema = {
  "@type": "RoofingContractor",
  "@id": "https://trueroof.com.au/#business",
  "name": "True Roof",
  "url": "https://trueroof.com.au",
  "telephone": "0400 000 000",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": location.data.title,
    "postalCode": location.data.postcode,
    "addressRegion": "VIC",
    "addressCountry": "AU"
  },
  ...(location.data.coordinates ? {
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": location.data.coordinates.lat,
      "longitude": location.data.coordinates.lng
    }
  } : {}),
  "areaServed": {
    "@type": "City",
    "name": location.data.title
  }
};

const schemas = [locationSchema];

if (locationFaqs.length > 0) {
  schemas.push({
    "@type": "FAQPage",
    "@id": `https://trueroof.com.au/locations/${slug}#faq`,
    "mainEntity": locationFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}

---
<MainLayout title={pageTitle} description={pageDescription} schema={schemas}>

  {/* ── Location Hero ── */}
  <section class="hero-section pt-24 pb-20" style={`position: relative; overflow: hidden; ${location.data.hero ? `background: url(${location.data.hero}) center/cover no-repeat;` : ''}`}>
    {location.data.hero && (
      <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(15,15,15,0.7) 0%, rgba(15,15,15,0.9) 100%); z-index: 1;"></div>
    )}
    <div class="hero-content" style="position: relative; z-index: 2;">
      <div class="hero-badge">📍 {location.data.title} — Postcode {location.data.postcode}</div>
      <h1 class="hero-headline" style="font-size: clamp(2.5rem, 6vw, 4rem); text-shadow: 0 4px 20px rgba(0,0,0,0.5);">
        {headline}
      </h1>
      <p class="hero-sub" style="max-width: 42rem; font-size: 1.15rem; color: rgba(255,255,255,0.85);">{location.data.description}</p>
      <div class="hero-ctas">
        <a href="#quote" class="cta-primary">📋 Get a Free Quote</a>
        <a href="tel:0400000000" class="cta-secondary" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">📞 Call Us Now</a>
      </div>
    </div>
  </section>

  {/* ── Local Stats ── */}
  {(location.data.localStats || location.data.localCommonRoofTypes) && (
    <section style="padding: 3rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <div class="container">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.25rem;">
          {location.data.localStats?.avgRoofAge && (
            <div class="stat-card">
              <div class="stat-value">{location.data.localStats.avgRoofAge}</div>
              <div class="stat-label">Avg Roof Age</div>
            </div>
          )}
          {location.data.localStats?.lastStormDate && (
            <div class="stat-card">
              <div class="stat-value">{location.data.localStats.lastStormDate}</div>
              <div class="stat-label">Last Major Storm</div>
            </div>
          )}
          {location.data.localCommonRoofTypes && (
            <div class="stat-card" style="grid-column: span 2;">
              <div class="stat-label" style="margin-bottom: 0.75rem;">Common Roof Types</div>
              <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
                {location.data.localCommonRoofTypes.map((type: string) => (
                  <span class="badge">{type}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {/* ── Location Content ── */}
  {/* 📐 Pixel: Enforcing F-Pattern reading mode alongside a sticky Z-Pattern CTA aside */}
  <section class="py-16">
    <div class="container grid grid-cols-1 md:grid-cols-[1fr_20rem] gap-8 md:gap-16 items-start">
      <div class="content-prose max-w-prose">
        <Content />

        {/* Service Focus */}
        {location.data.serviceFocus && (
          <div style="margin-top: 2.5rem;">
            <h3>Our Services in {location.data.title}</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem;">
              {location.data.serviceFocus.map((s: string) => (
                <span class="badge">{s}</span>
              ))}
            </div>
          </div>
        )}

        {/* Nearby Suburbs */}
        {location.data.nearbySuburbs && location.data.nearbySuburbs.length > 0 && (
          <div style="margin-top: 2rem;">
            <h3>We Also Service Nearby</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem;">
              {location.data.nearbySuburbs.map((suburb: string) => (
                <span class="badge" style="background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.6); border-color: rgba(255,255,255,0.1);">{suburb}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Sidebar */}
      <aside class="md:sticky md:top-24">
        <div class="glass-card" style="padding: 2rem; text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">📋</div>
          <h3 style="font-family: Outfit, sans-serif; font-weight: 800; font-size: 1.15rem; color: white; margin-bottom: 0.5rem;">
            Free Inspection in {location.data.title}
          </h3>
          <p style="color: rgba(255,255,255,0.45); font-size: 0.85rem; line-height: 1.5; margin-bottom: 1.25rem;">
            We service {location.data.title} and surrounds.
          </p>
          <a href="#quote" class="cta-primary" style="width: 100%; font-size: 0.9rem;">Get Your {location.data.title} Quote</a>
        </div>

        {/* Services links */}
        <div class="glass-card" style="padding: 1.5rem; margin-top: 1rem;">
          <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Our Services</div>
          {services.map(s => (
            <a href={`/services/${s.slug}`} style="display: block; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.87rem; padding: 0.375rem 0; transition: color 0.2s;" onmouseover="this.style.color='#f97316'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">{s.data.title}</a>
          ))}
        </div>
      </aside>
    </div>
  </section>

  {/* ── FAQs ── */}
  {locationFaqs.length > 0 && (
    <section class="section-dark py-16">
      <div class="container" style="max-width: 48rem;">
        <h2 class="section-heading" style="text-align: center; margin-bottom: 2rem;">
          FAQs for <span class="accent-text">{location.data.title}</span>
        </h2>
        <FAQAccordion client:visible items={locationFaqs} />
      </div>
    </section>
  )}

  {/* ── Quote Section ── */}
  {/* 📐 Pixel: Enforcing Z-Pattern flow towards the lead capture form on desktop */}
  <section id="quote" class="quote-section">
    <div class="container grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div>
        <h2 class="section-heading" style="margin-bottom: 1rem;">
          Roof Restoration in<br/><span class="accent-text">{location.data.title}</span>
        </h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem;">
          Get a free inspection and detailed quote for your {location.data.title} property.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <span class="badge">✅ Serving {location.data.postcode}</span>
          <span class="badge">✅ Free Inspection</span>
        </div>
        <PromoCard contextType="location" locationName={location.data.title} />

        {/* 🧠 Convert UX: Placing social proof immediately adjacent to the lead capture form significantly increases conversion rates by providing third-party validation at the highest point of friction. */}
        <div class="glass-card" style="margin-top: 2rem; padding: 1.5rem; background: rgba(255,255,255,0.02); border-left: 4px solid var(--color-brand-orange);">
          <div style="display: flex; gap: 0.25rem; color: #f59e0b; margin-bottom: 0.75rem; font-size: 1.1rem;">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p style="color: rgba(255,255,255,0.8); font-size: 0.95rem; line-height: 1.6; font-style: italic; margin-bottom: 1rem;">
            "These guys are the real deal. Had a leak for months that two other companies couldn't fix. True Roof found it in 10 minutes and sorted the whole roof. Highly recommend."
          </p>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 2.5rem; height: 2.5rem; background: rgba(249, 115, 22, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Outfit', sans-serif; font-weight: 700; color: white;">
              MB
            </div>
            <div>
              <div style="font-family: 'Outfit', sans-serif; font-weight: 700; color: white; font-size: 0.95rem;">Mark B.</div>
              <div style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">{location.data.title}, Verified Customer</div>
            </div>
          </div>
        </div>
      </div>
      <QuoteForm client:visible ctx={weatherContext} />
    </div>
  </section>

</MainLayout>
