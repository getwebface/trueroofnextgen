---
/**
 * TextureTechnology.astro
 *
 * Full-bleed cinematic section showcasing the "Texture Psychology" video.
 * Placed between the Process Steps and Locations sections on the homepage.
 *
 * Video URL: /cdn/Texture_Psychology_Tile_Transformation_Video.mp4
 * Auto-plays, muted, looped — demonstrating the hydrophobic coating science.
 */
---

<section id="technology" class="texture-section">
  <!-- Background ambient glow -->
  <div class="texture-bg-glow" aria-hidden="true"></div>

  <div class="container">
    <!-- Section label -->
    <div class="texture-eyebrow">
      <span class="texture-label-dot"></span>
      <span>Surface Science</span>
    </div>

    <!-- Headline -->
    <div class="texture-header">
      <h2 class="section-heading texture-headline">
        See the <span class="accent-text">Difference</span><br />in 7 Seconds
      </h2>
      <p class="section-subheading texture-sub">
        Our premium coating transforms your tile's surface at a molecular level — creating a
        hydrophobic barrier that repels water, blocks mould spores, and extends roof life by
        15-20 years. Two tiles. One truth.
      </p>
    </div>

    <!-- The main video showcase -->
    <div class="texture-stage">

      <!-- Left label: Before -->
      <div class="texture-panel-label label-before">
        <div class="label-pill label-pill-before">
          <span class="label-dot dot-red"></span>
          Before Treatment
        </div>
        <p class="label-desc">Porous terracotta absorbs water instantly — accelerating mould, erosion &amp; structural decay.</p>
      </div>

      <!-- Video frame -->
      <div class="texture-video-wrap">
        <!-- Decorative corner accents -->
        <div class="corner corner-tl" aria-hidden="true"></div>
        <div class="corner corner-tr" aria-hidden="true"></div>
        <div class="corner corner-bl" aria-hidden="true"></div>
        <div class="corner corner-br" aria-hidden="true"></div>

        <!-- Subtle scan-line overlay for cinematic texture -->
        <div class="video-scanlines" aria-hidden="true"></div>

        <!-- The video itself -->
        <video
          id="texture-video"
          class="texture-video"
          src="/cdn/Texture_Psychology_Tile_Transformation_Video.mp4"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="Before and after comparison: water being absorbed into an untreated porous tile versus beading off a hydrophobic coated tile"
        ></video>

        <!-- Midpoint divider line -->
        <div class="video-mid-line" aria-hidden="true">
          <div class="mid-line-inner"></div>
        </div>

        <!-- Floating "lotus effect" callout -->
        <div class="video-callout">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          <span>Lotus-Effect Coating</span>
        </div>
      </div>

      <!-- Right label: After -->
      <div class="texture-panel-label label-after">
        <div class="label-pill label-pill-after">
          <span class="label-dot dot-green"></span>
          After Treatment
        </div>
        <p class="label-desc">Water molecules bead and roll away — zero absorption, maximum protection.</p>
      </div>

    </div><!-- /texture-stage -->

    <!-- Proof points row -->
    <div class="texture-proofs">
      <div class="proof-item">
        <div class="proof-icon">
          <!-- Droplet icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" />
          </svg>
        </div>
        <div class="proof-text">
          <strong>100% Hydrophobic</strong>
          <span>Zero water absorption post-treatment</span>
        </div>
      </div>

      <div class="proof-divider" aria-hidden="true"></div>

      <div class="proof-item">
        <div class="proof-icon">
          <!-- UV icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </div>
        <div class="proof-text">
          <strong>UV Stabilised</strong>
          <span>Colour-fast under Melbourne's harsh summers</span>
        </div>
      </div>

      <div class="proof-divider" aria-hidden="true"></div>

      <div class="proof-item">
        <div class="proof-icon">
          <!-- Shield icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <div class="proof-text">
          <strong>15–20 Year Lifespan</strong>
          <span>Restores &amp; extends at a fraction of replace cost</span>
        </div>
      </div>

      <div class="proof-divider" aria-hidden="true"></div>

      <div class="proof-item">
        <div class="proof-icon">
          <!-- Mould/leaf icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#orange-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22V12M12 12C12 6 6 2 2 2s4 10 10 10m0 0c0-6 6-10 10-10s-6 10-10 10"/>
          </svg>
        </div>
        <div class="proof-text">
          <strong>Anti-Mould Formula</strong>
          <span>Seals out moss &amp; lichen spores permanently</span>
        </div>
      </div>
    </div><!-- /texture-proofs -->

    <!-- CTA -->
    <div class="texture-cta-wrap">
      <a href="#quote" class="cta-primary accent-glow">
        Get Your Free Coating Quote
      </a>
      <a href="#process" class="cta-secondary">
        See Our Full Process →
      </a>
    </div>

  </div><!-- /container -->
</section>

<style>
  /* ── Section wrapper ── */
  .texture-section {
    position: relative;
    padding: 6rem 0 5rem;
    background: var(--color-brand-deep);
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Ambient diagonal glow */
  .texture-bg-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249, 115, 22, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 100%, rgba(249, 115, 22, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ── Eyebrow label ── */
  .texture-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand-orange);
  }

  .texture-label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-orange);
    box-shadow: 0 0 8px rgba(249, 115, 22, 0.6);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.4); }
  }

  /* ── Headline block ── */
  .texture-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem 4rem;
    align-items: end;
    margin-bottom: 3.5rem;
  }

  .texture-headline {
    margin-bottom: 0;
  }

  .texture-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    max-width: 38ch;
  }

  /* ── Stage: labels + video ── */
  .texture-stage {
    display: grid;
    grid-template-columns: 1fr 3fr 1fr;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 3.5rem;
  }

  /* ── Panel labels ── */
  .texture-panel-label {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .label-before { text-align: right; }
  .label-after  { text-align: left; }

  .label-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .label-pill-before {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #fca5a5;
    margin-left: auto;
  }

  .label-pill-after {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.25);
    color: #86efac;
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red   { background: #ef4444; box-shadow: 0 0 6px rgba(239, 68, 68, 0.7); }
  .dot-green { background: #22c55e; box-shadow: 0 0 6px rgba(34, 197, 94, 0.7); }

  .label-desc {
    font-size: 0.8rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  /* ── Video wrapper ── */
  .texture-video-wrap {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 0 0 1px rgba(249, 115, 22, 0.1),
      0 40px 120px rgba(0, 0, 0, 0.6),
      0 0 60px rgba(249, 115, 22, 0.06);
    background: #0a0a0a;
    aspect-ratio: 16 / 9;
  }

  /* Corner accent marks */
  .corner {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 10;
    opacity: 0.5;
  }

  .corner-tl {
    top: 10px; left: 10px;
    border-top: 2px solid var(--color-brand-orange);
    border-left: 2px solid var(--color-brand-orange);
    border-radius: 4px 0 0 0;
  }
  .corner-tr {
    top: 10px; right: 10px;
    border-top: 2px solid var(--color-brand-orange);
    border-right: 2px solid var(--color-brand-orange);
    border-radius: 0 4px 0 0;
  }
  .corner-bl {
    bottom: 10px; left: 10px;
    border-bottom: 2px solid var(--color-brand-orange);
    border-left: 2px solid var(--color-brand-orange);
    border-radius: 0 0 0 4px;
  }
  .corner-br {
    bottom: 10px; right: 10px;
    border-bottom: 2px solid var(--color-brand-orange);
    border-right: 2px solid var(--color-brand-orange);
    border-radius: 0 0 4px 0;
  }

  /* Scanline texture overlay */
  .video-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.04) 3px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  /* The actual video */
  .texture-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Mid-divider line */
  .video-mid-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .mid-line-inner {
    width: 1px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 255, 255, 0.15) 20%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.15) 80%,
      transparent
    );
  }

  /* Floating callout badge */
  .video-callout {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1rem;
    background: rgba(15, 15, 25, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(249, 115, 22, 0.3);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.04em;
    white-space: nowrap;
    z-index: 10;
    animation: float-badge 3s ease-in-out infinite;
  }

  @keyframes float-badge {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-4px); }
  }

  /* ── Proof points ── */
  .texture-proofs {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 3rem;
  }

  .proof-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 2rem;
  }

  .proof-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(249, 115, 22, 0.08);
    border-radius: 0.625rem;
    flex-shrink: 0;
  }

  .proof-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .proof-text strong {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: white;
  }

  .proof-text span {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.4;
  }

  .proof-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  /* ── CTA row ── */
  .texture-cta-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .texture-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .texture-sub {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .texture-stage {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .texture-panel-label {
      flex-direction: row;
      align-items: center;
      gap: 1rem;
    }

    .label-before { text-align: left; }
    .label-before .label-pill { margin-left: 0; }
    .label-desc { display: none; }

    .texture-video-wrap {
      aspect-ratio: 16 / 10;
    }

    .proof-item {
      padding: 0.75rem 1rem;
    }

    .proof-divider {
      display: none;
    }
  }
</style>
