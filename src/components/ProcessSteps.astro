---
import { Droplets, Wrench, BrickWall, ShieldCheck, AlertTriangle, CloudRain, Snowflake } from 'lucide-react';
import SmartMedia from './SmartMedia.astro';

const { weatherContext } = Astro.locals;
const urgency = weatherContext?.urgency || 1;
const event = weatherContext?.event;

let steps = [
  {
    number: 1,
    title: 'High-Pressure Clean',
    description: 'Remove decades of moss, lichen, and grime with specialized equipment.',
    icon: Droplets,
    keywords: ['cleaning', 'pressure', 'moss', 'roof'],
  },
  {
    number: 2,
    title: 'Structural Repairs',
    description: 'Replace cracked tiles, check valleys, and repair all flashings.',
    icon: Wrench,
    keywords: ['repair', 'tile', 'flashings', 'structural'],
  },
  {
    number: 3,
    title: 'Re-bed & Flexi-Point',
    description: 'Strip old mortar. Apply modern flexible pointing that won\'t crack.',
    icon: BrickWall,
    keywords: ['rebedding', 'pointing', 'ridge', 'mortar'],
  },
  {
    number: 4,
    title: 'Protective Coating',
    description: 'Multi-coat membrane system to restore colour and seal against weather.',
    icon: ShieldCheck,
    keywords: ['coating', 'membrane', 'restoration', 'colour'],
  }
];

// Contextualize Step 1 and 2 based on weather urgency and event
if (urgency >= 4) {
  steps[0] = {
    number: 1,
    title: 'Emergency Make-Safe',
    description: `Immediate response to secure your roof against ${event === 'HAIL_STORM' ? 'hail' : event === 'HIGH_WIND' ? 'wind' : 'storm'} damage.`,
    icon: AlertTriangle,
    keywords: ['emergency', 'tarp', 'secure', 'storm', 'damage'],
  };
  steps[1] = {
    number: 2,
    title: 'Damage Assessment',
    description: 'Comprehensive evaluation of structural integrity and detailed reporting.',
    icon: Wrench,
    keywords: ['repair', 'assessment', 'inspection', 'structural'],
  };
} else if (event === 'HEAVY_RAIN' || event === 'DRIZZLE') {
  steps[0] = {
    number: 1,
    title: 'Active Leak Detection',
    description: 'We use the current rain to pinpoint the exact source of your water ingress.',
    icon: CloudRain,
    keywords: ['leak', 'detection', 'rain', 'inspection'],
  };
} else if (event === 'FROST') {
  steps[1] = {
    number: 2,
    title: 'Freeze-Thaw Assessment',
    description: 'Inspect mortar and tiles for micro-cracks caused by overnight frost.',
    icon: Snowflake,
    keywords: ['inspection', 'frost', 'cracks', 'mortar'],
  };
}

const subheading = urgency >= 4
  ? "When weather strikes, we adapt our 4-stage process to prioritize your immediate safety and structural integrity."
  : "Every restoration follows our meticulous 4-stage process — no shortcuts, just quality craftsmanship.";
---
<section class="process-section" id="process">
  <div class="container">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 class="section-heading">Our Proven <span class="accent-text">4-Stage</span> Process</h2>
      <p class="section-subheading" style="margin-left: auto; margin-right: auto;">
        {subheading}
      </p>
    </div>

    <div class="relative w-full h-2 bg-slate-800 rounded mb-8">
      <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none">
        <path d="M0,4 L1000,4" stroke="#f97316" stroke-width="2" class="animate-pulse drop-shadow-[0_0_8px_rgba(249,115,22,0.8)]" />
      </svg>
      <div class="absolute left-1/4 top-1/2 -translate-y-1/2 w-4 h-4 bg-orange-500 rounded-full shadow-[0_0_12px_#f97316] hover:scale-125 transition-transform"></div>
    </div>

    <div class="process-grid">
      {steps.map(step => {
        const Icon = step.icon;
        return (
          <div class="process-step">
            {/* SmartMedia thumbnail — adds visual context to each step */}
            <div class="process-step-media" aria-hidden="true">
              <SmartMedia
                contextKeywords={step.keywords}
                alt=""
                cssClass="process-step-img"
                preferredType="image"
              />
              <div class="process-step-media-overlay" aria-hidden="true"></div>
            </div>

            <div class="process-number">{step.number}</div>
            <div style="margin-bottom: 1rem; display: flex; justify-content: center;">
              <Icon size={32} strokeWidth={1.5} stroke="url(#orange-gradient)" />
            </div>
            <h4>{step.title}</h4>
            <p>{step.description}</p>
          </div>
        )
      })}
    </div>
  </div>
</section>

<style>
  /* Each step gets a contextual image panel at the top */
  .process-step {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 0;
    transition: border-color 0.3s, transform 0.3s;
  }

  .process-step:hover {
    border-color: rgba(249, 115, 22, 0.25);
    transform: translateY(-4px);
  }

  /* Media thumbnail at the top of each card */
  .process-step-media {
    position: relative;
    width: 100%;
    height: 140px;
    overflow: hidden;
    border-radius: 1.25rem 1.25rem 0 0;
    background: linear-gradient(135deg, rgba(249,115,22,0.05), rgba(15,15,35,0.8));
  }

  .process-step-media .process-step-img,
  .process-step-media .smart-media-picture,
  .process-step-media .smart-media-img,
  .process-step-media .smart-media-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    min-height: 140px;
  }

  /* Gradient fades image into card body below */
  .process-step-media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(10, 10, 20, 0.65) 70%,
      rgba(10, 10, 20, 0.98) 100%
    );
    pointer-events: none;
  }

  /* Card body content sits below the image */
  .process-step .process-number,
  .process-step > div:not(.process-step-media),
  .process-step h4,
  .process-step p {
    position: relative;
    z-index: 1;
  }

  .process-step h4,
  .process-step p,
  .process-step > div:not(.process-step-media):not(:first-child) {
    padding: 0 1.5rem;
  }

  .process-step .process-number {
    margin: -1.75rem auto 0.75rem;
    position: relative;
    z-index: 2;
  }

  .process-step > div:last-of-type {
    padding-bottom: 1.75rem;
  }
</style>