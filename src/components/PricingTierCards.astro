---
import SmartMedia from './SmartMedia.astro';
---
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 my-8 items-stretch">

  {/* ── Clean tier ── */}
  <div class="glass-card pricing-card pricing-card--basic">
    <div class="pricing-media-wrap" aria-hidden="true">
      <SmartMedia
        contextKeywords={['cleaning', 'moss', 'pressure', 'wash']}
        alt=""
        cssClass="pricing-media"
        preferredType="image"
      />
      <div class="pricing-media-overlay"></div>
      <div class="pricing-tier-badge">Clean</div>
    </div>
    <div class="pricing-body">
      <p class="text-sm text-white/70 mb-4">Basic maintenance to remove growth.</p>
      <ul class="list-none p-0 text-sm text-left mb-6 space-y-2">
        <li>✅ Biological Decontamination</li>
        <li>✅ High-Pressure Wash</li>
        <li class="text-white/30">❌ Structural Repairs</li>
        <li class="text-white/30">❌ Re-bedding &amp; Pointing</li>
      </ul>
      <a href="#quote" class="cta-secondary block w-full text-center">Select</a>
    </div>
  </div>

  {/* ── Point tier (Most Popular) ── */}
  <div class="glass-card pricing-card pricing-card--popular relative md:scale-105 z-10">
    <div class="pricing-media-wrap" aria-hidden="true">
      <SmartMedia
        contextKeywords={['rebedding', 'pointing', 'ridge', 'repair', 'tile']}
        alt=""
        cssClass="pricing-media"
        preferredType="image"
      />
      <div class="pricing-media-overlay"></div>
      <div class="pricing-popular-badge">MOST POPULAR</div>
      <div class="pricing-tier-badge pricing-tier-badge--white">Point</div>
    </div>
    <div class="pricing-body">
      <p class="text-sm text-white/70 mb-4">Essential repairs for older roofs.</p>
      <ul class="list-none p-0 text-sm text-left mb-6 space-y-2">
        <li>✅ Biological Decontamination</li>
        <li>✅ High-Pressure Wash</li>
        <li>✅ Structural Repairs</li>
        <li>✅ Re-bedding &amp; Pointing</li>
      </ul>
      <a href="#quote" class="cta-primary block w-full text-center">Select</a>
    </div>
  </div>

  {/* ── Full Restoration tier ── */}
  <div class="glass-card pricing-card pricing-card--premium">
    <div class="pricing-media-wrap" aria-hidden="true">
      <SmartMedia
        contextKeywords={['restoration', 'coating', 'membrane', 'colour', 'tile']}
        alt=""
        cssClass="pricing-media"
        preferredType="image"
      />
      <div class="pricing-media-overlay"></div>
      <div class="pricing-tier-badge pricing-tier-badge--amber">Full Restoration</div>
    </div>
    <div class="pricing-body">
      <p class="text-sm text-white/70 mb-4">Complete aesthetic &amp; structural overhaul.</p>
      <ul class="list-none p-0 text-sm text-left mb-6 space-y-2">
        <li>✅ Everything in Point</li>
        <li>✅ Protective Membrane</li>
        <li>✅ Custom Color Coating</li>
        <li>✅ 10-Year Warranty</li>
      </ul>
      <a href="#quote" class="cta-secondary block w-full text-center">Select</a>
    </div>
  </div>

</div>

<style>
  .pricing-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* The image area at the top of each pricing card */
  .pricing-media-wrap {
    position: relative;
    width: 100%;
    height: 160px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pricing-media-wrap .pricing-media,
  .pricing-media-wrap .smart-media-picture,
  .pricing-media-wrap .smart-media-img,
  .pricing-media-wrap .smart-media-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    min-height: 160px;
  }

  /* Gradient fade into card body */
  .pricing-media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,10,20,0.2) 0%,
      rgba(10,10,20,0.98) 100%
    );
    pointer-events: none;
  }

  /* Floating tier name badge at the bottom of the image area */
  .pricing-tier-badge {
    position: absolute;
    bottom: 0.75rem;
    left: 1.25rem;
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: #60a5fa;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .pricing-tier-badge--white { color: white; }
  .pricing-tier-badge--amber { color: #f59e0b; }

  /* Most popular chip on image */
  .pricing-popular-badge {
    position: absolute;
    top: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: #3b82f6;
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.875rem;
    border-radius: 9999px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  .pricing-body {
    padding: 1.25rem 1.5rem 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .pricing-body ul {
    flex: 1;
  }

  /* Make the featured middle card feel elevated */
  .pricing-card--popular {
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.15), 0 20px 60px rgba(0,0,0,0.4);
  }

  .pricing-card--premium .pricing-media-wrap {
    background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(15,15,35,0.9));
  }
</style>
