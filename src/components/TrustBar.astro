---
// src/components/TrustBar.astro
import { ShieldCheck, Star, Construction, MapPin, CircleCheck } from 'lucide-react';
---
<div class="trust-bar">
  <div class="trust-item">
    <div class="trust-icon"><ShieldCheck size={20} strokeWidth={1.5} stroke="url(#orange-gradient)" /></div>
    <span>Licensed & Insured</span>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><Star size={20} strokeWidth={1.5} stroke="url(#orange-gradient)" /></div>
    <span>5-Star Google Rating</span>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><Construction size={20} strokeWidth={1.5} stroke="url(#orange-gradient)" /></div>
    <span>25+ Years Experience</span>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><MapPin size={20} strokeWidth={1.5} stroke="url(#orange-gradient)" /></div>
    <span>100% Melbourne Owned</span>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><CircleCheck size={20} strokeWidth={1.5} stroke="url(#orange-gradient)" /></div>
    <span>Free Roof Inspections</span>
  </div>
</div>
