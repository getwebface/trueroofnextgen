---
// src/layouts/MainLayout.astro
import '../index.css';
import Analytics from '../components/Analytics.astro';
import WeatherBanner from '../components/WeatherBanner.astro';
import SVGGradients from '../components/SVGGradients.astro';
import { Phone, ClipboardList, ShieldCheck } from 'lucide-react';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const { weatherContext, weatherCSSMode } = Astro.locals;
const cssMode = weatherCSSMode || 'weather-default';
const urgency = weatherContext?.urgency || 1;
const city = weatherContext?.city || 'Melbourne';
const isEmergency = urgency >= 4;
const ctaLabel = isEmergency ? '🚨 Emergency Call' : 'Free Quote';

// SEO: Canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://trueroof.com.au');

// SEO: RoofingContractor Schema
// Note: Google Guidelines specify that LocalBusiness schema must accurately reflect NAP (Name, Address, Phone).
// Using the phone number present on the page. Address details are generalized to Melbourne area.
const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "True Roof",
  "url": "https://trueroof.com.au",
  "telephone": "0400 000 000",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Melbourne",
    "addressRegion": "VIC",
    "addressCountry": "AU"
  },
  "areaServed": {
    "@type": "City",
    "name": "Melbourne"
  }
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || "True Roof — Melbourne Tile Restoration Specialists"}</title>
    <link rel="canonical" href={canonicalURL} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    <meta name="description" content={description || "Melbourne's trusted tile restoration experts. Professional cleaning, re-bedding, flexi-pointing, metal flashing repairs. Free inspections. 25+ years experience."} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@700;800;900&display=swap" />
    <script is:inline define:vars={{ weatherCtxJSON: JSON.stringify(weatherContext || {}) }}>
      try { window.__WEATHER_CTX__ = JSON.parse(weatherCtxJSON); } catch(e) {}
    </script>
    <Analytics />
  </head>
  <body class={cssMode}>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <SVGGradients />

    <!-- Weather Banner (always visible) -->
    <WeatherBanner />

    <!-- Sticky Navbar -->
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="nav-logo">True<span>Roof</span></a>
        <ul class="nav-links">
          <li><a href="/#services">Services</a></li>
          <li><a href="/#process">Our Process</a></li>
          <li><a href="/#locations">Locations</a></li>
          <li><a href="#quote">Get a Quote</a></li>
        </ul>
        <div style="display: flex; align-items: center; gap: 1rem;">
          <a href="tel:0400000000" class="nav-phone">
            <Phone size={18} strokeWidth={1.5} stroke="url(#orange-gradient)" />
            <span>0400 000 000</span>
          </a>
          <a href={isEmergency ? 'tel:0400000000' : '#quote'} class="cta-primary" style="padding: 0.6rem 1.5rem; font-size: 0.85rem;">
            {isEmergency && <Phone size={16} strokeWidth={1.5} stroke="white" className="mr-1" />}
            {ctaLabel}
          </a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <!-- Typographic watermark: brand authority background -->
      <div class="footer-watermark" aria-hidden="true">
        <span>TRUE ROOF</span>
      </div>
      <div class="footer-content">
        <div class="container">
          <div class="footer-grid">
            <div>
              <div class="footer-brand">True<span>Roof</span></div>
              <p class="footer-desc">
                Melbourne's trusted tile restoration specialists. We restore terracotta and concrete tile roofs
                using our proven 4-stage process — no shortcuts, just quality craftsmanship backed by 25+ years of experience.
              </p>
              <a href="tel:0400000000" class="cta-primary" style="padding: 0.6rem 1.25rem; font-size: 0.85rem; gap: 0.5rem; display: inline-flex; align-items: center;">
                <Phone size={18} strokeWidth={1.5} stroke="white" /> Call Us Now
              </a>
            </div>
            <div>
              <div class="footer-heading">Services</div>
              <ul class="footer-links">
                <li><a href="/services/tiled-restoration">Tile Restoration</a></li>
                <li><a href="/services/cleaning">Roof Cleaning</a></li>
                <li><a href="/services/metal-flashings">Metal Flashings</a></li>
                <li><a href="#quote">Free Inspection</a></li>
              </ul>
            </div>
            <div>
              <div class="footer-heading">Locations</div>
              <ul class="footer-links">
                <li><a href="/locations/melbourne">Melbourne</a></li>
                <li><a href="/locations/wallan">Wallan</a></li>
              </ul>
            </div>
            <div>
              <div class="footer-heading">Contact</div>
              <ul class="footer-links" style="display: flex; flex-direction: column; gap: 0.5rem;">
                <li><a href="tel:0400000000">0400 000 000</a></li>
                <li><a href="mailto:info@trueroof.com.au">info@trueroof.com.au</a></li>
                <li style="display: flex; align-items: center; gap: 0.5rem;">
                  <ShieldCheck size={16} strokeWidth={1.5} stroke="url(#orange-gradient)" />
                  <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">Licensed & Insured</span>
                </li>
              </ul>
            </div>
          </div>
          <div class="footer-bottom">
            &copy; {new Date().getFullYear()} True Roof. All rights reserved. Melbourne, Australia.
          </div>
        </div>
      </div>
    </footer>

    <!-- Sticky Mobile CTA Bar -->
    <div class="mobile-cta">
      <a href="tel:0400000000" class="cta-primary" style="font-size: 0.85rem; gap: 0.375rem; display: inline-flex; align-items: center;">
        <Phone size={18} strokeWidth={1.5} stroke="white" /> Call Now
      </a>
      <a href="#quote" class="cta-secondary" style="font-size: 0.85rem; gap: 0.375rem; display: inline-flex; align-items: center;">
        <ClipboardList size={18} strokeWidth={1.5} stroke="url(#orange-gradient)" /> Free Quote
      </a>
    </div>

  </body>
</html>
