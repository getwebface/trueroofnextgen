---
// src/layouts/MainLayout.astro
import '../index.css';
import Analytics from '../components/Analytics.astro';
import WeatherBanner from '../components/WeatherBanner.astro';

const { weatherContext, weatherCSSMode } = Astro.locals;
const cssMode = weatherCSSMode || 'weather-default';
const urgency = weatherContext?.urgency || 1;
const city = weatherContext?.city || 'Melbourne';
const isEmergency = urgency >= 4;
const ctaLabel = isEmergency ? '🚨 Emergency Call' : 'Free Quote';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>True Roof — Melbourne Tile Restoration Specialists</title>
    <meta name="description" content="Melbourne's trusted tile restoration experts. Professional cleaning, re-bedding, flexi-pointing, metal flashing repairs. Free inspections. 25+ years experience." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline define:vars={{ weatherCtxJSON: JSON.stringify(weatherContext || {}) }}>
      try { window.__WEATHER_CTX__ = JSON.parse(weatherCtxJSON); } catch(e) {}
    </script>
    <Analytics />
  </head>
  <body class={cssMode}>

    <!-- Weather Banner (always visible) -->
    <WeatherBanner />

    <!-- Sticky Navbar -->
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="nav-logo">True<span>Roof</span></a>
        <ul class="nav-links">
          <li><a href="/#services">Services</a></li>
          <li><a href="/#process">Our Process</a></li>
          <li><a href="/#locations">Locations</a></li>
          <li><a href="#quote">Get a Quote</a></li>
        </ul>
        <div style="display: flex; align-items: center; gap: 1rem;">
          <a href="tel:0400000000" class="nav-phone">
            <span>📞</span>
            <span>0400 000 000</span>
          </a>
          <a href={isEmergency ? 'tel:0400000000' : '#quote'} class="cta-primary" style="padding: 0.6rem 1.5rem; font-size: 0.85rem;">
            {ctaLabel}
          </a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <div class="footer-brand">True<span>Roof</span></div>
            <p class="footer-desc">
              Melbourne's trusted tile restoration specialists. We restore terracotta and concrete tile roofs
              using our proven 4-stage process — no shortcuts, just quality craftsmanship backed by 25+ years of experience.
            </p>
            <a href="tel:0400000000" class="cta-primary" style="padding: 0.6rem 1.25rem; font-size: 0.85rem;">
              📞 Call Us Now
            </a>
          </div>
          <div>
            <div class="footer-heading">Services</div>
            <ul class="footer-links">
              <li><a href="/services/tiled-restoration">Tile Restoration</a></li>
              <li><a href="/services/cleaning">Roof Cleaning</a></li>
              <li><a href="/services/metal-flashings">Metal Flashings</a></li>
              <li><a href="#quote">Free Inspection</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Locations</div>
            <ul class="footer-links">
              <li><a href="/locations/melbourne">Melbourne</a></li>
              <li><a href="/locations/wallan">Wallan</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Contact</div>
            <ul class="footer-links">
              <li><a href="tel:0400000000">0400 000 000</a></li>
              <li><a href="mailto:info@trueroof.com.au">info@trueroof.com.au</a></li>
              <li><span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">Licensed & Insured</span></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          &copy; {new Date().getFullYear()} True Roof. All rights reserved. Melbourne, Australia.
        </div>
      </div>
    </footer>

    <!-- Sticky Mobile CTA Bar -->
    <div class="mobile-cta">
      <a href="tel:0400000000" class="cta-primary" style="font-size: 0.85rem;">📞 Call Now</a>
      <a href="#quote" class="cta-secondary" style="font-size: 0.85rem;">📋 Free Quote</a>
    </div>

  </body>
</html>
